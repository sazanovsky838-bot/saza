#include <iostream>
using namespace std; 
int main() {

  setlocale(LC_ALL, "Russian");
  int numb; 
  cout << "Введите длину массива";
  cin >> numb;

  int *arr = new int[numb]; 

  cout << "Введите любые числа массива" << endl;
  for (int i = 0; i < numb; i++) {
    cin >> arr[i];
  }

  
  int sum = 0; 

  for (int i = 0; i < numb; i++) {
    sum += arr[i]; 
  }

  double averange = double(sum) / numb; 

  cout << averange; 

  delete[] arr; 
}
